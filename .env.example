# Murphy Method — client environment variables.
#
# Copy this file to `.env` and fill in your own local/dev Supabase project's
# values. `.env` is git-ignored (see .gitignore) — never commit real values.
#
# Both variables below are PUBLIC by design (the `EXPO_PUBLIC_` prefix is
# inlined into the client bundle by Expo/Metro at build time — anything
# placed here is not a secret). Only the Supabase anon/publishable key
# belongs here. Never add a service-role key, database password, or
# Supabase access token to this file or to any EXPO_PUBLIC_* variable —
# those are server-only and must live in Supabase Edge Function secrets,
# never in client configuration. See docs/SUPABASE_SETUP.md.

# Your Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
# For local development against `supabase start`, this is http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_URL=

# Your Supabase project's publishable (anon) key — safe for client use.
# Find it in Supabase Dashboard → Project Settings → API, or from
# `supabase start`'s local output.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
